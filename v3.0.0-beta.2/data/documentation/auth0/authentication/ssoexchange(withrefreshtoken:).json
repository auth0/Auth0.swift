xt":"Please reach out to Auth0 support to get it enabled for your tenant.","type":"text"}]},{"type":"heading","level":2,"text":"Usage","anchor":"Usage"},{"code":["Auth0","    .authentication()","    .ssoExchange(refreshToken: credentials.refreshToken)","    .start { result in","        switch result {","        case .success(let ssoCredentials):","            print(\"Obtained new SSO credentials: \\(ssoCredentials)\")","        case .failure(let error):","            print(\"Failed with: \\(error)\")","        }","    }"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"When opening your website on any browser or web view, add the session transfer token to the URL as a query","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parameter. Then your website can redirect the user to Auth0’s "},{"type":"codeVoice","code":"\/authorize"},{"type":"text","text":" endpoint, passing along the query"},{"text":" ","type":"text"},{"text":"parameter with the session transfer token. For example,","type":"text"},{"text":" ","type":"text"},{"code":"https:\/\/example.com\/login?session_transfer_token=THE_TOKEN","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"If you’re using ","type":"text"},{"code":"WKWebView","type":"codeVoice"},{"type":"text","text":" to open your website, you can place the session transfer token inside a cookie"},{"text":" ","type":"text"},{"type":"text","text":"instead. It will be automatically sent to the "},{"code":"\/authorize","type":"codeVoice"},{"text":" endpoint.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let cookie = HTTPCookie(properties: [","    .domain: \"YOUR_AUTH0_DOMAIN\", \/\/ Or custom domain, if your website is using one","    .path: \"\/\",","    .name: \"auth0_session_transfer_token\",","    .value: ssoCredentials.sessionTransferToken,","    .expires: ssoCredentials.expiresAt,","    .secure: true","])!","","webView.configuratio