{"abstract":[{"type":"text","text":"Exchanges the refresh token for a session transfer token that can be used to perform web single sign-on (SSO)."},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"This method is thread-safe"}]},{"type":"text","text":"."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["iOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ssoCredentials","kind":"identifier"},{"text":"(","kind":"text"},{"text":"parameters","kind":"externalParam"},{"text":": [","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"text":" : ","kind":"text"},{"text":"Any","kind":"keyword"},{"text":"] = [:], ","kind":"text"},{"text":"headers","kind":"externalParam"},{"text":": [","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":"] = [:]) -> "},{"text":"AnyPublisher","kind":"typeIdentifier","preciseIdentifier":"s:7Combine12AnyPublisherV"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","identifier":"doc:\/\/com.auth0.Auth0\/documentation\/Auth0\/SSOCredentials","preciseIdentifier":"s:5Auth014SSOCredentialsV","text":"SSOCredentials"},{"kind":"text","text":", "},{"identifier":"doc:\/\/com.auth0.Auth0\/documentation\/Auth0\/CredentialsManagerError","kind":"typeIdentifier","preciseIdentifier":"s:5Auth023CredentialsManagerErrorV","text":"CredentialsManagerError"},{"text":">","kind":"text"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"parameters","content":[{"type":"paragraph","inlineContent":[{"text":"Additional parameters to use.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Additional headers to use."}]}],"name":"headers"}]},{"kind":"content","content":[{"level":2,"text":"Usage","anchor":"Usage","type":"heading"},{"code":["credentialsManager","    .ssoCredentials()","    .sink(receiveCompletion: { completion in","        if case .failure(let error) = completion {","            print(\"Failed with: \\(error)\")","        }","    }, receiveValue: { ssoCredentials in","        print(\"Obtained SSO credentials: \\(ssoCredentials)\")","    })","    .store(in: &cancellables)"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to specify custom parameters or headers:"}]},{"syntax":"swift","code":["credentialsManager","    .ssoCredentials(parameters: [\"key\": \"value\"],","                    headers: [\"key\": \"value\"])","    .sink(receiveCompletion: { print($0) },","          receiveValue: { print($0) })","    .store(in: &cancellables)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When opening your website on any browser or web view, add the session transfer token to the URL as a query"},{"type":"text","text":" "},{"text":"parameter. Then your website can redirect the user to Auth0’s ","type":"text"},{"code":"\/authorize","type":"codeVoice"},{"text":" endpoint, passing along the query","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parameter with the session transfer token. For example,"},{"text":" ","type":"text"},{"code":"https:\/\/example.com\/login?session_transfer_token=THE_TOKEN","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"If you’re using "},{"type":"codeVoice","code":"WKWebView"},{"text":" to open your website, you can place the session transfer token inside a cookie","type":"text"},{"type":"text","text":" "},{"type":"text","text":"instead. It will be automatically sent to the "},{"type":"codeVoice","code":"\/authorize"},{"type":"text","text":" endpoint."}],"type":"paragraph"},{"code":["let cookie = HTTPCookie(properties: [","    .domain: \"YOUR_AUTH0_DOMAIN\", \/\/ Or custom domain, if your website is using one","  