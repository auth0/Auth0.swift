pe":"paragraph"},{"code":["let cookie = HTTPCookie(properties: [","    .domain: \"YOUR_AUTH0_DOMAIN\", \/\/ Or custom domain, if your website is using one","    .path: \"\/\",","    .name: \"auth0_session_transfer_token\",","    .value: ssoCredentials.sessionTransferToken,","    .expires: ssoCredentials.expiresIn,","    .secure: true","])!","","webView.configuration.websiteDataStore.httpCookieStore.setCookie(cookie)"],"type":"codeListing","syntax":"swift"},{"content":[{"inlineContent":[{"type":"text","text":"Make sure the cookie’s domain matches the Auth0 domain your "},{"inlineContent":[{"text":"website","type":"text"}],"type":"emphasis"},{"text":" is using, regardless of the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"one your mobile app is using. Otherwise, the "},{"type":"codeVoice","code":"\/authorize"},{"text":" endpoint will not receive the cookie. If your website","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is using the provided Auth0 domain (like "},{"code":"example.us.auth0.com","type":"codeVoice"},{"type":"text","text":"), set the cookie’s domain to this value. On the"},{"type":"text","text":" "},{"text":"other hand, if your website is using a custom domain, use this value instead.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"important","name":"Important"},{"name":"Requires","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The scope "},{"code":"offline_access","type":"codeVoice"},{"type":"text","text":" to have been requested on login to get a refresh token from Auth0. If"},{"text":" ","type":"text"},{"type":"text","text":"there is no refresh token, the callback will be called with a "},{"isActive":true,"identifier":"doc:\/\/com.auth0.Auth0\/documentation\/Auth0\/CredentialsManagerError\/noRefreshToken","type":"reference"},{"text":" error.","type":"text"}]}],"style":"note","type":"aside"},{"style":"important","name":"Important","content":[{"type":"paragraph","inlineContent":