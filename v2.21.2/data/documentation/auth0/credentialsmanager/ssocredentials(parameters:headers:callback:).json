xt":"Usage","anchor":"Usage","level":2,"type":"heading"},{"type":"codeListing","code":["credentialsManager.ssoCredentials { result in","    switch result {","    case .success(let ssoCredentials):","        print(\"Obtained SSO credentials: \\(ssoCredentials)\")","    case .failure(let error):","        print(\"Failed with: \\(error)\")","    }","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"If you need to specify custom parameters or headers:"}],"type":"paragraph"},{"code":["credentialsManager.ssoCredentials(parameters: [\"key\": \"value\"],","                                  headers: [\"key\": \"value\"]) { print($0) }"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"When opening your website on any browser or web view, add the session transfer token to the URL as a query","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"parameter. Then your website can redirect the user to Auth0’s "},{"code":"\/authorize","type":"codeVoice"},{"text":" endpoint, passing along the query","type":"text"},{"text":" ","type":"text"},{"text":"parameter with the session transfer token. For example,","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"https:\/\/example.com\/login?session_transfer_token=THE_TOKEN"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If you’re using ","type":"text"},{"type":"codeVoice","code":"WKWebView"},{"type":"text","text":" to open your website, you can place the session transfer token inside a cookie"},{"type":"text","text":" "},{"text":"instead. It will be automatically sent to the ","type":"text"},{"type":"codeVoice","code":"\/authorize"},{"text":" endpoint.","type":"text"}]},{"syntax":"swift","code":["let cookie = HTTPCookie(properties: [","    .domain: \"YOUR_AUTH0_DOMAIN\", \/\/ Or custom domain, if your website is using one","    .path: \"\/\",","    .name: \"auth0_session_transfer_token\",","    .value: ssoCredentials.sessionTransferToken,","    .expires: ssoCredentials.expiresIn,","    .secure: true","])!","","webView.configuration.websiteDataStore.httpCookieStore.setCookie(cookie)"],"type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Make sure the cookie’s domain matches the Auth0 domain your ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"website"}]},{"type":"text","text":" is using, regardless of the"},{"type":"text","text":" "},{"type":"text","text":"one your mobile app is using. Otherwise, the "},{"type":"codeVoice","code":"\/authorize"},{"text":" endpoint will not receive the cookie. If your website","type":"text"},{"type":"text","text":" "},{"text":"is using the provided Auth0 domain (like ","type":"text"},{"type":"codeVoice","code":"example.us.auth0.com"},{"text":"), set the cookie’s domain to this value. On the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"other hand, if your website is using a custom domain, use this value instead."}]}],"type":"aside","style":"important","name":"Important"},{"content":[{"inlineContent":[{"type":"text","text":"The scope "},{"type":"codeVoice","code":"offline_access"},{"type":"text","text":" to have been requested on login to get a refresh token from Auth0. If"},{"type":"text","text":" "},{"text":"there is no refresh token, the callback will be called with a ","type":"text"},{"identifier":"doc:\/\/com.auth0.Auth0\/documentation\/Auth0\/CredentialsManagerError\/noRefreshToken","type":"reference","isActive":true},{"text":" error.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Requires"},{"name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"To ensure that no concurrent renewal requests get made, do not call this method from multiple","type":"text"},{"type":"text","text":" "},{"text":"Credentials Manager instances. The Credentials Manager cannot synchronize requests across instances.","type":"text"}]}],"style":"important","type":"