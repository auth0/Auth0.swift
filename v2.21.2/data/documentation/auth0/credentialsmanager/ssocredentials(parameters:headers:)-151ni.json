e":"codeListing"},{"style":"important","name":"Important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Make sure the cookie’s domain matches the Auth0 domain your "},{"type":"emphasis","inlineContent":[{"text":"website","type":"text"}]},{"type":"text","text":" is using, regardless of the"},{"type":"text","text":" "},{"text":"one your mobile app is using. Otherwise, the ","type":"text"},{"type":"codeVoice","code":"\/authorize"},{"text":" endpoint will not receive the cookie. If your website","type":"text"},{"text":" ","type":"text"},{"text":"is using the provided Auth0 domain (like ","type":"text"},{"type":"codeVoice","code":"example.us.auth0.com"},{"text":"), set the cookie’s domain to this value. On the","type":"text"},{"text":" ","type":"text"},{"text":"other hand, if your website is using a custom domain, use this value instead.","type":"text"}]}],"type":"aside"},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"The scope ","type":"text"},{"code":"offline_access","type":"codeVoice"},{"text":" to have been requested on login to get a refresh token from Auth0. If","type":"text"},{"text":" ","type":"text"},{"text":"there is no refresh token, the callback will be called with a ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.auth0.Auth0\/documentation\/Auth0\/CredentialsManagerError\/noRefreshToken","isActive":true},{"text":" error.","type":"text"}]}],"name":"Requires"},{"style":"important","type":"aside","content":[{"inlineContent":[{"type":"text","text":"To ensure that no concurrent renewal requests get made, do not call this method from multiple"},{"type":"text","text":" "},{"type":"text","text":"Credentials Manager instances. The Credentials Manager cannot synchronize requests across instances."}],"type":"paragraph"}],"name":"Important"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/auth0\/credentialsmanager\/ssocredentials(paramete