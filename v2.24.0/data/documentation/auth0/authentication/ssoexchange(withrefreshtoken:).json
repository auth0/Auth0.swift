"type":"text"}],"type":"paragraph"},{"anchor":"Usage","text":"Usage","type":"heading","level":2},{"type":"codeListing","syntax":"swift","code":["Auth0","    .authentication()","    .ssoExchange(refreshToken: credentials.refreshToken)","    .start { result in","        switch result {","        case .success(let ssoCredentials):","            print(\"Obtained new SSO credentials: \\(ssoCredentials)\")","        case .failure(let error):","            print(\"Failed with: \\(error)\")","        }","    }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When opening your website on any browser or web view, add the session transfer token to the URL as a query"},{"type":"text","text":" "},{"text":"parameter. Then your website can redirect the user to Auth0’s ","type":"text"},{"code":"\/authorize","type":"codeVoice"},{"type":"text","text":" endpoint, passing along the query"},{"text":" ","type":"text"},{"text":"parameter with the session transfer token. For example,","type":"text"},{"text":" ","type":"text"},{"code":"https:\/\/example.com\/login?session_transfer_token=THE_TOKEN","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"If you’re using ","type":"text"},{"code":"WKWebView","type":"codeVoice"},{"text":" to open your website, you can place the session transfer token inside a cookie","type":"text"},{"type":"text","text":" "},{"text":"instead. It will be automatically sent to the ","type":"text"},{"type":"codeVoice","code":"\/authorize"},{"text":" endpoint.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let cookie = HTTPCookie(properties: [","    .domain: \"YOUR_AUTH0_DOMAIN\", \/\/ Or custom domain, if your website is using one","    .path: \"\/\",","    .name: \"auth0_session_transfer_token\",","    .value: ssoCredentials.sessionTransferToken,","    .expires: ssoCredentials.expiresIn,","    .secure: true","])!","","webView.configuration.websiteDataStore.httpCookieStore.setCookie(cookie)"]},