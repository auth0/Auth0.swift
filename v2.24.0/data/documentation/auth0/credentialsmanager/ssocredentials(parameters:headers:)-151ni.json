":[{"inlineContent":[{"text":"Additional headers to use.","type":"text"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"type":"heading","anchor":"Usage","level":2,"text":"Usage"},{"syntax":"swift","code":["credentialsManager","    .ssoCredentials()","    .sink(receiveCompletion: { completion in","        if case .failure(let error) = completion {","            print(\"Failed with: \\(error)\")","        }","    }, receiveValue: { ssoCredentials in","        print(\"Obtained SSO credentials: \\(ssoCredentials)\")","    })","    .store(in: &cancellables)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"If you need to specify custom parameters or headers:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["credentialsManager","    .ssoCredentials(parameters: [\"key\": \"value\"],","                    headers: [\"key\": \"value\"])","    .sink(receiveCompletion: { print($0) },","          receiveValue: { print($0) })","    .store(in: &cancellables)"]},{"type":"paragraph","inlineContent":[{"text":"When opening your website on any browser or web view, add the session transfer token to the URL as a query","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"parameter. Then your website can redirect the user to Auth0’s "},{"type":"codeVoice","code":"\/authorize"},{"type":"text","text":" endpoint, passing along the query"},{"text":" ","type":"text"},{"type":"text","text":"parameter with the session transfer token. For example,"},{"type":"text","text":" "},{"type":"codeVoice","code":"https:\/\/example.com\/login?session_transfer_token=THE_TOKEN"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"If you’re using ","type":"text"},{"code":"WKWebView","type":"codeVoice"},{"type":"text","text":" to open your website, you can place the session transfer token inside a cookie"},{"type":"text","text":" "},{"text":"instead. It will be automatically sent to the ","type":"text"},{"code":"\/authorize","type":"codeVoice"},{"type":"text","text":" endpoint."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let cookie = HTTPCookie(properties: [","    .domain: \"YOUR_AUTH0_DOMAIN\", \/\/ Or custom domain, if your website is using one","    .path: \"\/\",","    .name: \"auth0_session_transfer_token\",","    .value: ssoCredentials.sessionTransferToken,","    .expires: ssoCredentials.expiresIn,","    .secure: true","])!","","webView.configuration.websiteDataStore.httpCookieStore.setCookie(cookie)"]},{"name":"Important","content":[{"inlineContent":[{"text":"Make sure the cookie’s domain matches the Auth0 domain your ","type":"text"},{"inlineContent":[{"text":"website","type":"text"}],"type":"emphasis"},{"text":" is using, regardless of the","type":"text"},{"type":"text","text":" "},{"text":"one your mobile app is using. Otherwise, the ","type":"text"},{"type":"codeVoice","code":"\/authorize"},{"text":" endpoint will not receive the cookie. If your website","type":"text"},{"type":"text","text":" "},{"text":"is using the provided Auth0 domain (like ","type":"text"},{"code":"example.us.auth0.com","type":"codeVoice"},{"type":"text","text":"), set the cookie’s domain to this value. On the"},{"type":"text","text":" "},{"text":"other hand, if your website is using a custom domain, use this value instead.","type":"text"}],"type":"paragraph"}],"style":"important","type":"aside"},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The scope "},{"type":"codeVoice","code":"offline_access"},{"type":"text","text":" to have been requested on login to get a refresh token from Auth0. If"},{"type":"text","text":" "},{"type":"text","text":"there is no refresh token, the callback will be called with a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.auth0.Auth0\/documentation\/Auth0\/CredentialsManagerError\/noRefreshToken"},{"text":" error.","type":"text"}]}],"name":"Requires"},{"type":"aside","style":"important","name":"Importan