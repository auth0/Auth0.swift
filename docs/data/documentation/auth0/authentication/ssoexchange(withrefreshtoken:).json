       print(\"Failed with: \\(error)\")","        }","    }"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"When opening your website on any browser or web view, add the session transfer token to the URL as a query"},{"type":"text","text":" "},{"type":"text","text":"parameter. Then your website can redirect the user to Auth0’s "},{"code":"\/authorize","type":"codeVoice"},{"type":"text","text":" endpoint, passing along the query"},{"type":"text","text":" "},{"type":"text","text":"parameter with the session transfer token. For example,"},{"type":"text","text":" "},{"code":"https:\/\/example.com\/login?session_transfer_token=THE_TOKEN","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you’re using "},{"code":"WKWebView","type":"codeVoice"},{"type":"text","text":" to open your website, you can place the session transfer token inside a cookie"},{"type":"text","text":" "},{"type":"text","text":"instead. It will be automatically sent to the "},{"code":"\/authorize","type":"codeVoice"},{"type":"text","text":" endpoint."}],"type":"paragraph"},{"code":["let cookie = HTTPCookie(properties: [","    .domain: \"YOUR_AUTH0_DOMAIN\", \/\/ Or custom domain, if your website is using one","    .path: \"\/\",","    .name: \"auth0_session_transfer_token\",","    .value: ssoCredentials.sessionTransferToken,","    .expires: ssoCredentials.expiresIn,","    .secure: true","])!","","webView.configuration.websiteDataStore.httpCookieStore.setCookie(cookie)"],"syntax":"swift","type":"codeListing"},{"name":"Important","style":"important","content":[{"inlineContent":[{"text":"Make sure the cookie’s domain matches the Auth0 domain your ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"website","type":"text"}]},{"text":" is using, regardless of the","type":"text"},{"text":" ","type":"text"},{"text":"one your mobile app is using. Otherwise, the ","type":"text"},{"type":"codeVoice","code":"\/authorize"},{"text":" endpoint will not receive the cookie. If your website","type":"text"},{"text":" ","type":"text"},{"text":"is using the provided Auth0 domain (like ","type":"text"},{"type":"codeVoice","code":"example.us.auth0.com"},{"text":"), set the cookie’s domain to this value. On the","type":"text"},{"text":" ","type":"text"},{"text":"other hand, if your website is using a custom domain, use this value instead.","type":"text"}],"type":"paragraph"}],"type":"aside"}],"kind":"content"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/auth0\/authentication\/ssoexchange(withrefreshtoken:)"]}],"identifier":{"url":"doc:\/\/com.auth0.Auth0\/documentation\/Auth0\/Authentication\/ssoExchange(withRefreshToken:)","interfaceLanguage":"swift"},"references":{"https://auth0.com/docs/troubleshoot/product-lifecycle/product-release-stages#early-access":{"url":"https:\/\/auth0.com\/docs\/troubleshoot\/product-lifecycle\/product-release-stages#early-access","identifier":"https:\/\/auth0.com\/docs\/troubleshoot\/product-lifecycle\/product-release-stages#early-access","title":"Early Access","titleInlineContent":[{"text":"Early Access","type":"text"}],"type":"link"},"doc://com.auth0.Auth0/documentation/Auth0/SSOCredentials":{"url":"\/documentation\/auth0\/ssocredentials","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SSOCredentials","kind":"identifier"}],"identifier":"doc:\/\/com.auth0.Auth0\/documentation\/Auth0\/SSOCredentials","abstract":[{"text":"Credentials obtained from Auth0 to perform web single sign-on (SSO).","type":"text"}],"role":"symbol","type":"topic","kind":"symbol","title":"SSOCredentials","navigatorTitle":[{"text":"SSOCredentials","kind":"identifier"}]},"https://auth0.com/docs/api/authentication":{"titleInlineContent":[{"text":"Auth0 Authentication API","type":"text"}],"url":"https:\/\/auth0.com\/docs\/api\/authentication","title":"Auth0 Authentication API","type":"link","identif