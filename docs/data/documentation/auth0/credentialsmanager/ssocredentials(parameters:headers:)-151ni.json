e\/tokens\/refresh-tokens","https:\/\/auth0.com\/docs\/api\/authentication#refresh-token","doc:\/\/com.auth0.Auth0\/documentation\/Auth0\/RefreshTokens"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ssoCredentials","kind":"identifier"},{"text":"(","kind":"text"},{"text":"parameters","kind":"externalParam"},{"text":": [","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"Any","kind":"keyword"},{"text":"] = [:], ","kind":"text"},{"text":"headers","kind":"externalParam"},{"text":": [","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":"] = [:]) -> ","kind":"text"},{"preciseIdentifier":"s:7Combine12AnyPublisherV","text":"AnyPublisher","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:5Auth014SSOCredentialsV","text":"SSOCredentials","identifier":"doc:\/\/com.auth0.Auth0\/documentation\/Auth0\/SSOCredentials","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:5Auth023CredentialsManagerErrorV","text":"CredentialsManagerError","identifier":"doc:\/\/com.auth0.Auth0\/documentation\/Auth0\/CredentialsManagerError","kind":"typeIdentifier"},{"text":">","kind":"text"}],"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["swift"]}]},{"parameters":[{"name":"parameters","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Additional parameters to use."}]}]},{"name":"headers","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Additional headers to use."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"text":"Usage","level":2,"anchor":"Usage","type":"heading"},{"syntax":"swift","code":["credentialsManager","    .ssoCredentials()","    .sink(receiveCompletion: { completion in","        if case .failure(let error) = completion {","            print(\"Failed with: \\(error)\")","        }","    }, receiveValue: { ssoCredentials in","        print(\"Obtained SSO credentials: \\(ssoCredentials)\")","    })","    .store(in: &cancellables)"],"type":"codeListing"},{"inlineContent":[{"text":"If you need to specify custom parameters or headers:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["credentialsManager","    .ssoCredentials(parameters: [\"key\": \"value\"],","                    headers: [\"key\": \"value\"])","    .sink(receiveCompletion: { print($0) },","          receiveValue: { print($0) })","    .store(in: &cancellables)"],"type":"codeListing"},{"inlineContent":[{"text":"When opening your website on any browser or web view, add the session transfer token to the URL as a query","type":"text"},{"text":" ","type":"text"},{"text":"parameter. Then your website can redirect the user to Auth0’s ","type":"text"},{"type":"codeVoice","code":"\/authorize"},{"text":" endpoint, passing along the query","type":"text"},{"text":" ","type":"text"},{"text":"parameter with the session transfer token. For example,","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"https:\/\/example.com\/login?session_transfer_token=THE_TOKEN"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If you’re using ","type":"text"},{"type":"codeVoice","code":"WKWebView"},{"text":" to open your website, you can place the session transfer token inside a cookie","type":"text"},{"text":" ","type":"text"},{"text":"instead. It will be automatically sent to the ","type":"text"},{"type":"codeVoice","code":"\/authorize"},{"text":" endpoint.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let cookie = HTTPCookie(properties: [","    .domain: \"YOUR_AUTH0_DOMAIN\", \/\/ Or custom domain, if your website is using one","    .path: \"\/\",","    .name: \"auth0_session_transfer_token\",","    .value: ssoCredentials.sessionTransferToken,","    .expires: ssoCredentials.expiresIn,","    .secure: true","])!","","webView.configuration.websiteDataStore.httpCookieStore.setCookie(cookie)"],"type":"codeListing"},{"name":"Important","style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Make sure the cookie’s domain matches the Auth0 domain your "},{"type":"emphasis","inlineContent":[{"type":"text","text":"website"}]},{"type":"text","text":" is using, regardless of the"},{"type":"text","text":" "},{"type":"text","text":"one your mobile app is using. Otherwise, the "},{"type":"codeVoice","code":"\/authorize"},{"type":"text","text":" endpoint will not receive the cookie. If your website"},{"type":"text","text":" "},{"type":"text","text":"is using the provided Auth0 domain (like "},{"type":"codeVoice","code":"example.us.auth0.com"},{"type":"text","text":"), set the cookie’s domain to this value. On the"},{"type":"text","text":" "},{"type":"text","text":"other hand, if your website is using a custom domain, use this value instead."}]}],"type":"aside"},{"name":"Requires","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The scope "},{"type":"codeVoice","code":"offline_access"},{"type":"text","text":" to have been requested on login to get a refresh token from Auth0. If"},{"type":"text","text":" "},{"type":"text","text":"there is no refresh token, the callback will be called with a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.auth0.Auth0\/documentation\/Auth0\/CredentialsManagerError\/noRefreshToken"},{"type":"text","text":" error."}]}],"type":"aside"},{"name":"Important","style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"To ensure that no concurrent renewal requests get made, do not call this method from multiple"},{"type":"text","text":" "},{"type":"text","text":"Credentials Manager instances. The Credentials Manager cannot synchronize requests across instances."