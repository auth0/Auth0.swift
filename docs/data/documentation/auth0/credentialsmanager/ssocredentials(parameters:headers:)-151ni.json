ineContent":[{"text":"Additional headers to use.","type":"text"}]}],"name":"headers"}],"kind":"parameters"},{"content":[{"anchor":"Usage","type":"heading","level":2,"text":"Usage"},{"type":"codeListing","syntax":"swift","code":["credentialsManager","    .ssoCredentials()","    .sink(receiveCompletion: { completion in","        if case .failure(let error) = completion {","            print(\"Failed with: \\(error)\")","        }","    }, receiveValue: { ssoCredentials in","        print(\"Obtained SSO credentials: \\(ssoCredentials)\")","    })","    .store(in: &cancellables)"]},{"inlineContent":[{"type":"text","text":"If you need to specify custom parameters or headers:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["credentialsManager","    .ssoCredentials(parameters: [\"key\": \"value\"],","                    headers: [\"key\": \"value\"])","    .sink(receiveCompletion: { print($0) },","          receiveValue: { print($0) })","    .store(in: &cancellables)"]},{"inlineContent":[{"text":"When opening your website on any browser or web view, add the session transfer token to the URL as a query","type":"text"},{"text":" ","type":"text"},{"text":"parameter. Then your website can redirect the user to Auth0’s ","type":"text"},{"type":"codeVoice","code":"\/authorize"},{"text":" endpoint, passing along the query","type":"text"},{"text":" ","type":"text"},{"text":"parameter with the session transfer token. For example,","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"https:\/\/example.com\/login?session_transfer_token=THE_TOKEN"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you’re using "},{"type":"codeVoice","code":"WKWebView"},{"type":"text","text":" to open your website, you can place the session transfer token inside a cookie"},{"type":"text","text":" "},{"type":"text","text":"instead. It will be automatically sent to the "},{"type":"codeVoice","code":"\/authorize"},{"type":"text","text":" endpoint."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let cookie = HTTPCookie(properties: [","    .domain: \"YOUR_AUTH0_DOMAIN\", \/\/ Or custom domain, if your website is using one","    .path: \"\/\",","    .name: \"auth0_session_transfer_token\",","    .value: ssoCredentials.sessionTransferToken,","    .expires: ssoCredentials.expiresIn,","    .secure: true","])!","","webView.configuration.websiteDataStore.httpCookieStore.setCookie(cookie)"]},{"name":"Important","style":"important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Make sure the cookie’s domain matches the Auth0 domain your ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"website","type":"text"}]},{"text":" is using, regardless of the","type":"text"},{"text":" ","type":"text"},{"text":"one your mobile app is using. Otherwise, the ","type":"text"},{"type":"codeVoice","code":"\/authorize"},{"text":" endpoint will not receive the cookie. If your website","type":"text"},{"text":" ","type":"text"},{"text":"is using the provided Auth0 domain (like ","type":"text"},{"type":"codeVoice","code":"example.us.auth0.com"},{"text":"), set the cookie’s domain to this value. On the","type":"text"},{"text":" ","type":"text"},{"text":"other hand, if your website is using a custom domain, use this value instead.","type":"text"}]}]},{"name":"Requires","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The scope "},{"code":"offline_access","type":"codeVoice"},{"type":"text","text":" to have been requested on login to get a refresh token from Auth0. If"},{"type":"text","text":" "},{"type":"text","text":"there is no refresh token, the callback will be called with a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.auth0.Auth0\/documentation\/Auth0\/CredentialsManagerError\/noRefreshToken"},{"type":"text","text":" error."}]}]},{"type":"aside","style":"important","name":"Important","con