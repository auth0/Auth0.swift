ves a ","type":"text"},{"code":"Result","type":"codeVoice"},{"text":" containing either the SSO credentials or an error.","type":"text"}],"type":"paragraph"}],"name":"callback"}]},{"kind":"content","content":[{"type":"heading","text":"Usage","level":2,"anchor":"Usage"},{"type":"codeListing","code":["credentialsManager.ssoCredentials { result in","    switch result {","    case .success(let ssoCredentials):","        print(\"Obtained SSO credentials: \\(ssoCredentials)\")","    case .failure(let error):","        print(\"Failed with: \\(error)\")","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"If you need to specify custom parameters or headers:","type":"text"}]},{"type":"codeListing","code":["credentialsManager.ssoCredentials(parameters: [\"key\": \"value\"],","                                  headers: [\"key\": \"value\"]) { print($0) }"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"When opening your website on any browser or web view, add the session transfer token to the URL as a query","type":"text"},{"text":" ","type":"text"},{"text":"parameter. Then your website can redirect the user to Auth0’s ","type":"text"},{"code":"\/authorize","type":"codeVoice"},{"text":" endpoint, passing along the query","type":"text"},{"text":" ","type":"text"},{"text":"parameter with the session transfer token. For example,","type":"text"},{"text":" ","type":"text"},{"code":"https:\/\/example.com\/login?session_transfer_token=THE_TOKEN","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If you’re using ","type":"text"},{"code":"WKWebView","type":"codeVoice"},{"text":" to open your website, you can place the session transfer token inside a cookie","type":"text"},{"text":" ","type":"text"},{"text":"instead. It will be automatically sent to the ","type":"text"},{"code":"\/authorize","type":"codeVoice"},{"text":" endpoint.","type":"text"}]},{"type":"codeListing","code":["let cookie = HTTPCookie