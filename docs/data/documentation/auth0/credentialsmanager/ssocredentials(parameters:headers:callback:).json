s","content":[{"inlineContent":[{"text":"Additional headers to use.","type":"text"}],"type":"paragraph"}]},{"name":"callback","content":[{"inlineContent":[{"text":"Callback that receives a ","type":"text"},{"type":"codeVoice","code":"Result"},{"text":" containing either the SSO credentials or an error.","type":"text"}],"type":"paragraph"}]}]},{"content":[{"anchor":"Usage","type":"heading","level":2,"text":"Usage"},{"syntax":"swift","type":"codeListing","code":["credentialsManager.ssoCredentials { result in","    switch result {","    case .success(let ssoCredentials):","        print(\"Obtained SSO credentials: \\(ssoCredentials)\")","    case .failure(let error):","        print(\"Failed with: \\(error)\")","    }","}"]},{"inlineContent":[{"type":"text","text":"If you need to specify custom parameters or headers:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["credentialsManager.ssoCredentials(parameters: [\"key\": \"value\"],","                                  headers: [\"key\": \"value\"]) { print($0) }"]},{"inlineContent":[{"type":"text","text":"When opening your website on any browser or web view, add the session transfer token to the URL as a query"},{"type":"text","text":" "},{"type":"text","text":"parameter. Then your website can redirect the user to Auth0’s "},{"code":"\/authorize","type":"codeVoice"},{"type":"text","text":" endpoint, passing along the query"},{"type":"text","text":" "},{"type":"text","text":"parameter with the session transfer token. For example,"},{"type":"text","text":" "},{"code":"https:\/\/example.com\/login?session_transfer_token=THE_TOKEN","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you’re using "},{"code":"WKWebView","type":"codeVoice"},{"type":"text","text":" to open your website, you can place the session transfer token inside a cookie"},{"type":"text","text":" "},{"type":"text","text":"instead. It will be automatically sent to the "},{"cod