\/\/example.com\/login?session_transfer_token=THE_TOKEN"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"If you’re using ","type":"text"},{"code":"WKWebView","type":"codeVoice"},{"text":" to open your website, you can place the session transfer token inside a cookie","type":"text"},{"text":" ","type":"text"},{"text":"instead. It will be automatically sent to the ","type":"text"},{"code":"\/authorize","type":"codeVoice"},{"text":" endpoint.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let cookie = HTTPCookie(properties: [","    .domain: \"YOUR_AUTH0_DOMAIN\", \/\/ Or custom domain, if your website is using one","    .path: \"\/\",","    .name: \"auth0_session_transfer_token\",","    .value: ssoCredentials.sessionTransferToken,","    .expires: ssoCredentials.expiresIn,","    .secure: true","])!","","webView.configuration.websiteDataStore.httpCookieStore.setCookie(cookie)"]},{"content":[{"inlineContent":[{"type":"text","text":"Make sure the cookie’s domain matches the Auth0 domain your "},{"inlineContent":[{"text":"website","type":"text"}],"type":"emphasis"},{"type":"text","text":" is using, regardless of the"},{"type":"text","text":" "},{"type":"text","text":"one your mobile app is using. Otherwise, the "},{"type":"codeVoice","code":"\/authorize"},{"type":"text","text":" endpoint will not receive the cookie. If your website"},{"type":"text","text":" "},{"type":"text","text":"is using the provided Auth0 domain (like "},{"type":"codeVoice","code":"example.us.auth0.com"},{"type":"text","text":"), set the cookie’s domain to this value. On the"},{"type":"text","text":" "},{"type":"text","text":"other hand, if your website is using a custom domain, use this value instead."}],"type":"paragraph"}],"type":"aside","style":"important","name":"Important"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The scope ","type":"text"},{"code":"offline_access","type":"codeVoice"},{"text":" to have been requested on login to get a refresh token from Auth0. If","type":"text"},{"text":" ","type":"text"},{"text":"there is no refresh token, the callback will be called with a ","type":"text"},{"identifier":"doc:\/\/com.auth0.Auth0\/documentation\/Auth0\/CredentialsManagerError\/noRefreshToken","isActive":true,"type":"reference"},{"text":" error.","type":"text"}]}],"type":"aside","style":"note","name":"Requires"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"To ensure that no concurrent renewal requests get made, do not call this method from multiple"},{"type":"text","text":" "},{"type":"text","text":"Credentials Manager instances. The Credentials Manager cannot synchronize requests across instances."}]}],"type":"aside","style":"important","name":"Important"}]}],"metadata":{"roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ssoCredentials","kind":"identifier"},{"text":"(","kind":"text"},{"text":"parameters","kind":"externalParam"},{"text":": [","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"Any","kind":"keyword"},{"text":"], ","kind":"text"},{"text":"headers","kind":"externalParam"},{"text":": [","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":"], ","kind":"text"},{"text":"callback","kind":"externalParam"},{"text":": (","kind":"text"},{"text":"CredentialsManagerResult","preciseIdentifier":"s:5Auth024CredentialsManagerResulta","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"SSOCredentials","preciseIdentifier":"s:5Auth014SSOCredentialsV","kind":"typeIdentifier"},{"text":">) -> ","kind":"text"},{"text":"Void","preciseIdentifier":"s:s4Voida","kind":"typeIdentifier"},{"text":")","kind":"text"}],"externalID":"s:5Auth018CredentialsManagerV03ssoB010parameters7headers8callb