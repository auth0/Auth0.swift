er or web view, add the session transfer token to the URL as a query"},{"type":"text","text":" "},{"type":"text","text":"parameter. Then your website can redirect the user to Auth0’s "},{"code":"\/authorize","type":"codeVoice"},{"type":"text","text":" endpoint, passing along the query"},{"type":"text","text":" "},{"type":"text","text":"parameter with the session transfer token. For example,"},{"type":"text","text":" "},{"code":"https:\/\/example.com\/login?session_transfer_token=THE_TOKEN","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you’re using "},{"code":"WKWebView","type":"codeVoice"},{"type":"text","text":" to open your website, you can place the session transfer token inside a cookie"},{"type":"text","text":" "},{"type":"text","text":"instead. It will be automatically sent to the "},{"code":"\/authorize","type":"codeVoice"},{"type":"text","text":" endpoint."}],"type":"paragraph"},{"code":["let cookie = HTTPCookie(properties: [","    .domain: \"YOUR_AUTH0_DOMAIN\", \/\/ Or custom domain, if your website is using one","    .path: \"\/\",","    .name: \"auth0_session_transfer_token\",","    .value: ssoCredentials.sessionTransferToken,","    .expires: ssoCredentials.expiresAt,","    .secure: true","])!","","webView.configuration.websiteDataStore.httpCookieStore.setCookie(cookie)"],"syntax":"swift","type":"codeListing"},{"name":"Important","style":"important","content":[{"inlineContent":[{"type":"text","text":"Make sure the cookie’s domain matches the Auth0 domain your "},{"type":"emphasis","inlineContent":[{"type":"text","text":"website"}]},{"type":"text","text":" is using, regardless of the"},{"type":"text","text":" "},{"type":"text","text":"one your mobile app is using. Otherwise, the "},{"type":"codeVoice","code":"\/authorize"},{"type":"text","text":" endpoint will not receive the cookie. If your website"},{"type":"text","text":" "},{"type":"text","text":"is using the provided Auth0 domain (like